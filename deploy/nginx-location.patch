--- a/etc/nginx/nginx.conf
+++ b/etc/nginx/nginx.conf
@@ -63,15 +63,21 @@ http {
     server {
     		listen 443 ssl;
     		server_name localhost praticchat.duckdns.org;

     		# Path to the certificates you generated with mkcert
     		ssl_certificate /home/pratic/Desktop/chat-room-server/localhost.pem;
     		ssl_certificate_key /home/pratic/Desktop/chat-room-server/localhost-key.pem;

+		# Allow image/video uploads up to 100 MB (default 1 MB).
+		client_max_body_size 100m;
+
     		location / {
-        		proxy_pass http://127.0.0.1:8000;
+        		proxy_pass http://192.168.0.104:30800;
         		proxy_set_header Host $host;
         		proxy_set_header X-Real-IP $remote_addr;
