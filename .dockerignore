# Anything that ends up in the build context also ends up in the image
# unless explicitly excluded here. Keep this list conservative — the
# image should not carry secrets, VCS metadata, or your editor's swap
# files into someone else's cluster.

# Git
.git
.gitignore
.gitattributes

# Local secrets (the user runs the app from env at runtime)
.env
.env.*
!.env.example

# Runtime secrets generated by build_images.sh / deploy_k8s.sh
app/.env.runtime
k8s/secrets.runtime.yaml

# Python
__pycache__
**/__pycache__
*.pyc
.venv
venv
.pytest_cache
.mypy_cache
.coverage
htmlcov

# Editors / OS
.idea
.vscode
.DS_Store
Thumbs.db
*.swp
*.swo

# Local artefacts (bdy.tar.gz is a 40MB backup of misc stuff; not part of the image)
bdy.tar.gz

# Local TLS certs from the dev box — not part of the public image
*.pem
localhost.pem
localhost-key.pem

# Build / deploy scaffolding — never baked into the runtime image
Dockerfile
.dockerignore
k8s
mysql
deploy
scripts
Jenkinsfile
JENKINS_SETUP.md
BOOTSTRAP.md

# Docs / AI assistant state
README.md
CLAUDE.md
.claude