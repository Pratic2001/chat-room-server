# --- MySQL Database ---
# Used by app/database.py to build the SQLAlchemy connection URL:
#   mysql+pymysql://MYSQL_USER:MYSQL_PASSWORD@MYSQL_HOST/MYSQL_DB
MYSQL_USER=root
MYSQL_PASSWORD=3JT1fRDQLVgnWGXa0K41iDG6cf2NhMCYuSVxdjFL8
MYSQL_HOST=localhost
MYSQL_DB=chatroom_db

# --- JWT Authentication ---
# Used by app/utils.py for signing/verifying access tokens.
# Generate a strong key with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_a_long_random_secret_string_at_least_64_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
