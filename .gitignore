# Secrets — never commit credentials.
# Created by `scripts/create_env.sh`; rotate with `scripts/change_db_password.sh`.
.env
.env.*
!.env.example

# Generated by `scripts/build_images.sh` and consumed by `scripts/deploy_k8s.sh`.
# Lives next to `app/` so the deploy script can read it without a separate arg.
app/.env.runtime

# Rendered at build time from `mysql/init/99-grants.sql.template` by the
# MySQL Dockerfile; the template is what's checked in.
mysql/init/99-grants.sql

# Generated at deploy time by `scripts/deploy_k8s.sh`; never commit.
k8s/secrets.runtime.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

